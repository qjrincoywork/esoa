APP_NAME=eSOA
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
VC_ADMIN_DOMAIN=https://valucarehealth.com/esoa/admin/
APP_TIMEZONE=Asia/Manila

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlsrv
DB_HOST=127.0.0.1
DB_PORT=1433
DB_DATABASE=esoa
DB_USERNAME=
DB_PASSWORD=

HMS_DB_HOST=127.0.0.1
HMS_DB_DATABASE=HMS_db
HMS_DB_USERNAME=
HMS_DB_PASSWORD=
HMS_DB_TRUST_SERVER_CERTIFICATE=false

OI_DB_HOST=127.0.0.1
OI_DB_DATABASE=OI_Users
OI_DB_USERNAME=
OI_DB_PASSWORD=

SOA_DB_HOST=127.0.0.1
SOA_DB_PORT=1433
SOA_DB_DATABASE=SOA_db
SOA_DB_USERNAME=
SOA_DB_PASSWORD=
SOA_DB_TRUST_SERVER_CERTIFICATE=false

# SOA legacy upload migration (optional overrides)
SOA_IMPORT_CHUNK_SIZE=2000
SOA_IMPORT_LIMIT=
SOA_IMPORT_STATUS=0
SOA_IMPORT_DATE_FROM=2025-01-01
SOA_IMPORT_DATE_TO=2026-12-31
SOA_IMPORT_POC_START_FROM=2023-01-01

CENUSER_DB_HOST=127.0.0.1
CENUSER_DB_DATABASE=cenuser_db
CENUSER_DB_USERNAME=
CENUSER_DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
BILLING_DISK=billing
RM_DISK=rm
CONCERNS_DISK=concerns
ACCOUNT_PAYMENTS_DISK=payments
ROOT_FOLDER=
UPLOADS_FOLDER=
QUEUE_CONNECTION=database

MEMCACHED_HOST=127.0.0.1

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"
BILLING_NOTIFICATION_EMAIL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
BILLING_REMINDER_TIME=07:00
BILLING_REMINDER_TIMEOUT=3600
