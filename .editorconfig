root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml,css,scss,html,js,ts,jsx,tsx,json,vue,blade.php}]
indent_size = 2
indent_style = space

[docker-compose.yml]
indent_size = 4
